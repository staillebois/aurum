generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model App {
  id            String   @id @default(cuid())
  name          String
  icon          String
  description   String
  publisher     String
  category      String
  downloads     Int
  price         Float    @default(0)
  hasIap        Boolean  @default(false)
  hasSubscriptions Boolean @default(false)
  rating        Float
  reviewCount   Int
  estimatedMrr     Float?
  opportunityScore Int?
  aiSummary        String?
  painPoints       String?
  improvements     String?
  modelName        String?
  aiAnalyzedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reviews      Review[]
  competitors  Competitor[]
}

model Review {
  id        String   @id @default(cuid())
  appId     String
  text      String
  rating    Int
  userName  String?
  createdAt DateTime @default(now())

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
}

model AIAnalyticsReport {
  id                       String   @id @default(cuid())
  filterMinMrr             Float?
  filterMaxMrr             Float?
  filterMinScore           Float?
  filterMaxScore           Float?
  filterMinDownloads       Int?
  filterMaxDownloads       Int?
  filterMaxApps            Int?
  analyzedCount            Int
  recommendedCategory      String
  topAppName               String
  topAppReason             String
  keyInsights              String
  improvementThemes        String
  marketOverview           String?
  categoryReason           String?
  topApps                  String?
  monetizationAdvice       String?
  differentiationOpps      String?
  riskFactors              String?
  featurePriorities        String?
  targetAudience           String?
  analysisDurationMs       Int?
  analysisVersion          Int      @default(1)
  modelName                String
  createdAt                DateTime @default(now())
}

model Competitor {
  id            String  @id @default(cuid())
  appId         String
  name          String
  icon          String?
  downloads     Int?
  estimatedMrr  Float?

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
}